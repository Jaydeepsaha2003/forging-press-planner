{
  "name": "forge-planner",
  "version": "1.0.0",
  "description": "HIL ForgePlanner — Production Planning & Press Status Dashboard",
  "main": "dist-electron/main.js",
  "author": "HIL",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "build:unpack": "tsc -b && vite build && electron-builder --dir",
    "build:blank": "cross-env FORGE_BLANK=1 tsc -b && cross-env FORGE_BLANK=1 vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.20.5",
    "better-sqlite3": "^11.5.0",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^7.0.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4",
    "tsx": "^4.22.3",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.9.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.hil.forgeplanner",
    "productName": "HIL ForgePlanner",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "ForgePlanner-Setup-${version}.${ext}"
    }
  }
}
